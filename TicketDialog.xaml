<Window x:Class="AgilicoConnectChecker.TicketDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Raise Helpdesk Ticket" Height="480" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#f5f6fa" ShowInTaskbar="False" BorderThickness="1" BorderBrush="#cbd5e1">
    <Window.Resources>
        <!-- Resource references or local styles -->
        <SolidColorBrush x:Key="TextDarkBrush" Color="#0f172a"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#64748b"/>
        <SolidColorBrush x:Key="AccentNavyBrush" Color="#000034"/>
        <SolidColorBrush x:Key="AccentNavyHoverBrush" Color="#111155"/>
        
        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentNavyBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentNavyHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogSecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
            <Setter Property="BorderBrush" Value="#cbd5e1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#e2e8f0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Raise Helpdesk Ticket" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentNavyBrush}"/>
            <TextBlock Text="Submit diagnostic reports and network captures directly to Agilico Support." FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Form fields inside a card -->
        <Border Grid.Row="1" Background="White" CornerRadius="6" BorderBrush="#e2e8f0" BorderThickness="1" Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <!-- Email -->
                <TextBlock Text="Your Email Address:" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource TextDarkBrush}" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtEmail" Padding="8,6" Margin="0,0,0,12" FontSize="12" BorderBrush="#cbd5e1" BorderThickness="1"/>

                <!-- Subject -->
                <TextBlock Text="Subject:" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource TextDarkBrush}" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtSubject" Padding="8,6" Margin="0,0,0,12" FontSize="12" BorderBrush="#cbd5e1" BorderThickness="1"/>

                <!-- Description -->
                <TextBlock Text="Issue Details / Comments:" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource TextDarkBrush}" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtDescription" Height="110" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Padding="8,6" FontSize="12" BorderBrush="#cbd5e1" BorderThickness="1"/>

                <!-- Attachment Notice -->
                <Border Background="#f8fafc" BorderBrush="#e2e8f0" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,12,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Paperclip Icon -->
                        <Path Data="M16.5,6V17.5A4,4 0 0,1 12.5,21.5A4,4 0 0,1 8.5,17.5V5A2.5,2.5 0 0,1 11,2.5A2.5,2.5 0 0,1 13.5,5V15.5A1,1 0 0,1 12.5,16.5A1,1 0 0,1 11.5,15.5V6H10V15.5A2.5,2.5 0 0,0 12.5,18A2.5,2.5 0 0,0 15,15.5V5A4,4 0 0,0 11,1A4,4 0 0,0 7,5V17.5A5.5,5.5 0 0,0 12.5,23A5.5,5.5 0 0,0 18,17.5V6H16.5Z" 
                              Fill="{StaticResource TextMutedBrush}" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1" x:Name="TxtAttachmentsInfo" Text="Automatically attaching: diagnostic_report.txt, diagnostics.pcap" 
                                   FontSize="11" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <!-- Actions -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" x:Name="BtnCancel" Content="Cancel" Style="{StaticResource DialogSecondaryButtonStyle}" Click="BtnCancel_Click" Margin="0,0,10,0"/>
            <Button Grid.Column="2" x:Name="BtnCreateDraft" Content="Create Outlook Draft" Style="{StaticResource DialogButtonStyle}" Click="BtnCreateDraft_Click"/>
        </Grid>
    </Grid>
</Window>
