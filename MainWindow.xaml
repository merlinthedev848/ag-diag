                                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                    <TextBlock Text="NAT Routing &amp; Gateway Hops Check" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextDarkBrush}"/>
                                                    <TextBlock x:Name="Test6Details" Text="Pending" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <!-- Test 7: NAT Port Translation -->
                                        <Border BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,12" Cursor="Hand" MouseLeftButtonUp="TestRow_MouseUp" Background="Transparent">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
 
                                                <!-- CheckBox -->
                                                <CheckBox x:Name="ChkTest7" IsChecked="True" VerticalAlignment="Center" Margin="0,0,12,0" Grid.Column="0"/>

                                                <!-- Status Icon -->
                                                <Grid Grid.Column="1" VerticalAlignment="Center" Margin="0,0,15,0">
                                                    <Ellipse x:Name="Test7IconPending" Width="30" Height="30" Fill="#f1f5f9" Stroke="#cbd5e1" StrokeThickness="1"/>
                                                    <Ellipse x:Name="Test7IconRunning" Width="30" Height="30" Fill="#eff6ff" Stroke="{StaticResource AccentBlueBrush}" StrokeThickness="2" Visibility="Collapsed"/>
                                                    <Path x:Name="Test7Spinner" Data="{StaticResource IconSpinner}" Fill="{StaticResource AccentBlueBrush}" Width="16" Height="16" Stretch="Uniform" Visibility="Collapsed"/>
                                                    <Path x:Name="Test7IconPass" Data="{StaticResource IconCheck}" Fill="{StaticResource AccentGreenBrush}" Width="30" Height="30" Stretch="Uniform" Visibility="Collapsed"/>
                                                    <Path x:Name="Test7IconFail" Data="{StaticResource IconAlert}" Fill="{StaticResource AccentRedBrush}" Width="30" Height="30" Stretch="Uniform" Visibility="Collapsed"/>
                                                    <Path x:Name="Test7IconWarning" Data="{StaticResource IconAlert}" Fill="{StaticResource AccentWarningBrush}" Width="30" Height="30" Stretch="Uniform" Visibility="Collapsed"/>
                                                </Grid>
 
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                    <TextBlock Text="NAT Port Randomness Check" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextDarkBrush}"/>
                                                    <TextBlock x:Name="Test7Details" Text="Pending" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <!-- Test 8: SIP ALG Detection -->
                                        <Border BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,12" Cursor="Hand" MouseLeftButtonUp="TestRow_MouseUp" Background="Transparent">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
 
                                                <!-- CheckBox -->
                                                <CheckBox x:Name="ChkTest8" IsChecked="True" VerticalAlignment="Center" Margin="0,0,12,0" Grid.Column="0"/>

                                                <!-- Status Icon -->
                                                <Grid Grid.Column="1" VerticalAlignment="Center" Margin="0,0,15,0">
                                                    <Ellipse x:Name="Test8IconPending" Width="30" Height="30" Fill="#f1f5f9" Stroke="#cbd5e1" StrokeThickness="1"/>
                                                    <Ellipse x:Name="Test8IconRunning" Width="30" Height="30" Fill="#eff6ff" Stroke="{StaticResource AccentBlueBrush}" StrokeThickness="2" Visibility="Collapsed"/>
                                                    <Path x:Name="Test8Spinner" Data="{StaticResource IconSpinner}" Fill="{StaticResource AccentBlueBrush}" Width="16" Height="16" Stretch="Uniform" Visibility="Collapsed"/>
                                                    <Path x:Name="Test8IconPass" Data="{StaticResource IconCheck}" Fill="{StaticResource AccentGreenBrush}" Width="30" Height="30" Stretch="Uniform" Visibility="Collapsed"/>
                                                    <Path x:Name="Test8IconFail" Data="{StaticResource IconAlert}" Fill="{StaticResource AccentRedBrush}" Width="30" Height="30" Stretch="Uniform" Visibility="Collapsed"/>
                                                    <Path x:Name="Test8IconWarning" Data="{StaticResource IconAlert}" Fill="{StaticResource AccentWarningBrush}" Width="30" Height="30" Stretch="Uniform" Visibility="Collapsed"/>
                                                </Grid>
 
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                    <TextBlock Text="SIP ALG Detection (UDP Port 5060)" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextDarkBrush}"/>
                                                    <TextBlock x:Name="Test8Details" Text="Pending" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <!-- Test 9: RTP Jitter/Loss Check -->
                                        <Border BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,12" Cursor="Hand" MouseLeftButtonUp="TestRow_MouseUp" Background="Transparent">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
 
                                                <!-- CheckBox -->
                                                <CheckBox x:Name="ChkTest9" IsChecked="True" VerticalAlignment="Center" Margin="0,0,12,0" Grid.Column="0"/>

                                                <!-- Status Icon -->
                                                <Grid Grid.Column="1" VerticalAlignment="Center" Margin="0,0,15,0">
                                                    <Ellipse x:Name="Test9IconPending" Width="30" Height="30" Fill="#f1f5f9" Stroke="#cbd5e1" StrokeThickness="1"/>
                                                    <Ellipse x:Name="Test9IconRunning" Width="30" Height="30" Fill="#eff6ff" Stroke="{StaticResource AccentBlueBrush}" StrokeThickness="2" Visibility="Collapsed"/>
                                                    <Path x:Name="Test9Spinner" Data="{StaticResource IconSpinner}" Fill="{StaticResource AccentBlueBrush}" Width="16" Height="16" Stretch="Uniform" Visibility="Collapsed"/>
                                                    <Path x:Name="Test9IconPass" Data="{StaticResource IconCheck}" Fill="{StaticResource AccentGreenBrush}" Width="30" Height="30" Stretch="Uniform" Visibility="Collapsed"/>
                                                    <Path x:Name="Test9IconFail" Data="{StaticResource IconAlert}" Fill="{StaticResource AccentRedBrush}" Width="30" Height="30" Stretch="Uniform" Visibility="Collapsed"/>
                                                    <Path x:Name="Test9IconWarning" Data="{StaticResource IconAlert}" Fill="{StaticResource AccentWarningBrush}" Width="30" Height="30" Stretch="Uniform" Visibility="Collapsed"/>
                                                </Grid>
 
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                    <TextBlock Text="Advanced SIP Media (RTP) Quality Simulation" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextDarkBrush}"/>
                                                    <TextBlock x:Name="Test9Details" Text="Pending" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <!-- Test 10: Inbound Signalling & Presence (WebSockets) -->
                                        <Border BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,12" Cursor="Hand" MouseLeftButtonUp="TestRow_MouseUp" Background="Transparent">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
 
                                                <!-- CheckBox -->
                                                <CheckBox x:Name="ChkTest10" IsChecked="True" VerticalAlignment="Center" Margin="0,0,12,0" Grid.Column="0"/>

                                                <!-- Status Icon -->
                                                <Grid Grid.Column="1" VerticalAlignment="Center" Margin="0,0,15,0">
                                                    <Ellipse x:Name="Test10IconPending" Width="30" Height="30" Fill="#f1f5f9" Stroke="#cbd5e1" StrokeThickness="1"/>
                                                    <Ellipse x:Name="Test10IconRunning" Width="30" Height="30" Fill="#eff6ff" Stroke="{StaticResource AccentBlueBrush}" StrokeThickness="2" Visibility="Collapsed"/>
                                                    <Path x:Name="Test10Spinner" Data="{StaticResource IconSpinner}" Fill="{StaticResource AccentBlueBrush}" Width="16" Height="16" Stretch="Uniform" Visibility="Collapsed"/>
                                                    <Path x:Name="Test10IconPass" Data="{StaticResource IconCheck}" Fill="{StaticResource AccentGreenBrush}" Width="30" Height="30" Stretch="Uniform" Visibility="Collapsed"/>
                                                    <Path x:Name="Test10IconFail" Data="{StaticResource IconAlert}" Fill="{StaticResource AccentRedBrush}" Width="30" Height="30" Stretch="Uniform" Visibility="Collapsed"/>
                                                    <Path x:Name="Test10IconWarning" Data="{StaticResource IconAlert}" Fill="{StaticResource AccentWarningBrush}" Width="30" Height="30" Stretch="Uniform" Visibility="Collapsed"/>
                                                </Grid>
 
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                    <TextBlock Text="Inbound Signalling &amp; Presence (WebSockets)" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextDarkBrush}"/>
                                                    <TextBlock x:Name="Test10Details" Text="Pending" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- TAB 2: NET SCAN -->
                <TabItem>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header Area -->
                        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="10,0,10,10">
                            <Grid Margin="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Local Network LAN Scanner" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}"/>
                                    <TextBlock Text="Discovers all active devices connected to the local subnet using ICMP ping and ARP resolution." 
                                               TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,6,0,0"/>
                                </StackPanel>

                                <Button x:Name="BtnStartLanScan" Grid.Column="1" Style="{StaticResource ActionButtonStyle}" Click="BtnStartLanScan_Click" VerticalAlignment="Center" Padding="20,10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="SCAN NETWORK"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Results DataGrid -->
                        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="10,0,10,10">
                            <Grid Margin="20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <!-- Progress Area -->
                                <StackPanel Grid.Row="0" x:Name="PanelLanScanProgress" Orientation="Horizontal" Visibility="Collapsed" Margin="0,0,0,15">
                                    <Path Data="{StaticResource IconSpinner}" Fill="{StaticResource AccentBlueBrush}" Width="20" Height="20" Stretch="Uniform" RenderTransformOrigin="0.5,0.5">
                                        <Path.RenderTransform>
                                            <RotateTransform x:Name="LanSpinnerRotation" Angle="0"/>
                                        </Path.RenderTransform>
                                        <Path.Triggers>
                                            <EventTrigger RoutedEvent="Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="LanSpinnerRotation" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:1" RepeatBehavior="Forever"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Path.Triggers>
                                    </Path>
                                    <TextBlock x:Name="TxtLanScanProgress" Text="Scanning subnet (0/254)..." FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextDarkBrush}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- DataGrid -->
                                <DataGrid Grid.Row="1" x:Name="GridLanDevices" AutoGenerateColumns="False" IsReadOnly="True" 
                                          GridLinesVisibility="Horizontal" HeadersVisibility="Column" Background="Transparent" RowBackground="Transparent" AlternatingRowBackground="#f8fafc" BorderThickness="0" RowHeight="35">
                                    <DataGrid.Resources>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#f1f5f9"/>
                                            <Setter Property="Foreground" Value="#64748b"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Padding" Value="10,8"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Setter Property="BorderBrush" Value="#e2e8f0"/>
                                        </Style>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="Padding" Value="10,0"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="DataGridCell">
                                                        <Border Background="{TemplateBinding Background}" BorderThickness="0">
                                                            <ContentPresenter VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                        <Style x:Key="SelectableCellTextBox" TargetType="TextBox">
                                            <Setter Property="IsReadOnly" Value="True"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource AncestorType=DataGridCell}, Path=Foreground}"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="TextBox">
                                                        <ScrollViewer x:Name="PART_ContentHost" Focusable="False" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </DataGrid.Resources>
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="IP Address" Width="1.5*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding IpAddress, Mode=OneWay}" Style="{StaticResource SelectableCellTextBox}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="MAC Address" Width="1.5*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding MacAddress, Mode=OneWay}" Style="{StaticResource SelectableCellTextBox}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Hostname" Binding="{Binding Hostname}" Width="2*" />
                                        <DataGridTextColumn Header="Manufacturer (OUI)" Binding="{Binding Manufacturer}" Width="2*" />
                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*" >
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#10b981"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- TAB: PING TRACK -->
                <TabItem>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header / Controls Card -->
                        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="10,0,10,10">
                            <Grid Margin="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Ping Track (Connectivity Monitor)" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}"/>
                                    <TextBlock Text="Continuously monitors packet latency, jitter, and packet loss to a target host over time." 
                                               TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,6,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Target Host:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource TextDarkBrush}" Margin="0,0,8,0"/>
                                    <TextBox x:Name="TxtPingTarget" Width="150" Padding="8,6" Text="8.8.8.8" BorderBrush="{StaticResource BorderLightBrush}" SelectionBrush="{StaticResource AccentGreenBrush}" VerticalAlignment="Center" Margin="0,0,15,0"/>

                                    <TextBlock Text="Interval:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource TextDarkBrush}" Margin="0,0,8,0"/>
                                    <ComboBox x:Name="ComboPingInterval" Width="120" VerticalAlignment="Center" Margin="0,0,15,0">
                                        <ComboBoxItem Content="1.0 Second" Tag="1000" IsSelected="True"/>
                                        <ComboBoxItem Content="2.5 Seconds" Tag="2500"/>
                                        <ComboBoxItem Content="5.0 Seconds" Tag="5000"/>
                                        <ComboBoxItem Content="10.0 Seconds" Tag="10000"/>
                                    </ComboBox>

                                    <Button x:Name="BtnStartPingTrack" Style="{StaticResource ActionButtonStyle}" Click="BtnStartPingTrack_Click" Padding="15,10" Margin="0,0,10,0">
                                        <TextBlock Text="START TRACKING"/>
                                    </Button>

                                    <Button x:Name="BtnStopPingTrack" Style="{StaticResource ActionButtonStyle}" Background="{StaticResource AccentRedBrush}" Click="BtnStopPingTrack_Click" Padding="15,10" Margin="0,0,10,0" Visibility="Collapsed">
                                        <TextBlock Text="STOP"/>
                                    </Button>

                                    <Button x:Name="BtnDownloadPingLog" Style="{StaticResource SecondaryButtonStyle}" Content="Download Log" Click="BtnDownloadPingLog_Click" Padding="15,9"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Metrics Row -->
                        <Grid Grid.Row="1" Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Current Latency -->
                            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                                <StackPanel Margin="15,10">
                                    <TextBlock Text="Current Latency" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock x:Name="TxtPingCurrent" Text="0 ms" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentBlueBrush}" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Average Latency -->
                            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                                <StackPanel Margin="15,10">
                                    <TextBlock Text="Average Latency" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock x:Name="TxtPingAverage" Text="0 ms" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Min / Max -->
                            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                                <StackPanel Margin="15,10">
                                    <TextBlock Text="Min / Max Latency" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock x:Name="TxtPingMinMax" Text="0 / 0 ms" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Jitter -->
                            <Border Grid.Column="3" Style="{StaticResource CardStyle}">
                                <StackPanel Margin="15,10">
                                    <TextBlock Text="Jitter" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock x:Name="TxtPingJitter" Text="0 ms" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Packet Loss -->
                            <Border Grid.Column="4" Style="{StaticResource CardStyle}">
                                <StackPanel Margin="15,10">
                                    <TextBlock Text="Packet Loss" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock x:Name="TxtPingLoss" Text="0.0%" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Graph and Table area -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Graph Card -->
                            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                                <Grid Margin="15">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    
                                    <TextBlock Grid.Row="0" Text="Latency History (Last 60 Pings)" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}" Margin="0,0,0,10"/>
                                    
                                    <!-- Graph Container -->
                                    <Border Grid.Row="1" Background="#0f172a" CornerRadius="4" Padding="1">
                                        <Canvas x:Name="PingGraphCanvas" SizeChanged="PingGraphCanvas_SizeChanged" ClipToBounds="True" Background="Transparent"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Scrolling Log List Card -->
                            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                                <Grid Margin="15">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Text="Live Activity" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}" Margin="0,0,0,10"/>

                                    <DataGrid Grid.Row="1" x:Name="GridPingLogs" AutoGenerateColumns="False" IsReadOnly="True" 
                                              GridLinesVisibility="Horizontal" HeadersVisibility="Column" Background="Transparent" RowBackground="Transparent" AlternatingRowBackground="#f8fafc" BorderThickness="0" RowHeight="28" FontSize="11">
                                        <DataGrid.Resources>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="#f1f5f9"/>
                                                <Setter Property="Foreground" Value="#64748b"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="Padding" Value="6,4"/>
                                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                <Setter Property="BorderBrush" Value="#e2e8f0"/>
                                            </Style>
                                            <Style TargetType="DataGridCell">
                                                <Setter Property="Padding" Value="6,0"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="DataGridCell">
                                                            <Border Background="{TemplateBinding Background}" BorderThickness="0">
                                                                <ContentPresenter VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </DataGrid.Resources>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat=HH:mm:ss}" Width="Auto" />
                                            <DataGridTextColumn Header="Latency" Binding="{Binding LatencyDisplay}" Width="*" />
                                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="Auto">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="Text" Value="Success">
                                                                <Setter Property="Foreground" Value="#10b981"/>
                                                            </Trigger>
                                                            <Trigger Property="Text" Value="TimedOut">
                                                                <Setter Property="Foreground" Value="#ef4444"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- TAB 3: PROBE -->
                <TabItem>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Tab Header & Description -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,15">
                            <TextBlock Text="Probe Diagnostics" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}"/>
                            <TextBlock Text="Advanced troubleshooting utilities to probe outbound network ports, resolve DNS service locator records, and trace packet routes." 
                                       TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Tab Navigation for Probe Modules -->
                        <Grid Grid.Row="1" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="BtnProbeTrace" Style="{StaticResource ProbeTabButtonStyle}" Content="Traceroute Path Discovery" Click="BtnProbeTab_Click" Margin="0,0,10,0"/>
                            <Button x:Name="BtnProbePorts" Grid.Column="1" Style="{StaticResource ProbeTabButtonStyle}" Content="Outbound Port Prober" Click="BtnProbeTab_Click" Margin="0,0,10,0"/>
                            <Button x:Name="BtnProbeDns" Grid.Column="2" Style="{StaticResource ProbeTabButtonStyle}" Content="DNS SRV Locator" Click="BtnProbeTab_Click"/>
                        </Grid>

                        <!-- Sub-Tab Content Area -->
                        <TabControl Grid.Row="2" x:Name="ProbeTabControl" Background="Transparent" BorderThickness="0" Padding="0">
                            <TabControl.Resources>
                                <Style TargetType="TabItem">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </Style>
                            </TabControl.Resources>

                            <!-- Traceroute (Full Width) -->
                            <TabItem>
                                <Border Style="{StaticResource CardStyle}" Margin="0">
                                    <Grid Margin="15">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- Header -->
                                        <TextBlock Grid.Row="0" Text="Traceroute Path Discovery" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}" Margin="0,0,0,10"/>

                                        <!-- Controls -->
                                        <Grid Grid.Row="1" Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Target:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource TextDarkBrush}" Margin="0,0,10,0"/>
                                            <TextBox x:Name="TxtTraceTarget" Grid.Column="1" Height="32" Padding="8,6" Text="customerportal.hp2k.co.uk" BorderBrush="{StaticResource BorderLightBrush}" SelectionBrush="{StaticResource AccentGreenBrush}"/>
                                            <Grid Grid.Column="2" Margin="10,0,0,0">
                                                <Button x:Name="BtnStartTrace" Style="{StaticResource ActionButtonStyle}" Content="TRACE" Click="BtnStartTrace_Click" Padding="15,0" Height="32"/>
                                                <Button x:Name="BtnStopTrace" Style="{StaticResource ActionButtonStyle}" Background="{StaticResource AccentRedBrush}" Content="STOP" Click="BtnStopTrace_Click" Padding="15,0" Height="32" Visibility="Collapsed"/>
                                            </Grid>
                                        </Grid>

                                        <!-- Results Grid -->
                                        <DataGrid Grid.Row="2" x:Name="GridTraceHops" AutoGenerateColumns="False" IsReadOnly="True" 
                                                  GridLinesVisibility="Horizontal" HeadersVisibility="Column" Background="Transparent" RowBackground="Transparent" AlternatingRowBackground="#f8fafc" BorderThickness="0" RowHeight="32">
                                            <DataGrid.Resources>
                                                <Style TargetType="DataGridColumnHeader">
                                                    <Setter Property="Background" Value="#f1f5f9"/>
                                                    <Setter Property="Foreground" Value="#64748b"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="Padding" Value="8,6"/>
                                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource BorderLightBrush}"/>
                                                </Style>
                                                <Style TargetType="DataGridCell">
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Padding" Value="8,4"/>
                                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                                </Style>
                                            </DataGrid.Resources>
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Hop" Binding="{Binding HopNumber}" Width="50" />
                                                <DataGridTextColumn Header="IP Address" Binding="{Binding IpAddress}" Width="150" />
                                                <DataGridTextColumn Header="Hostname" Binding="{Binding Hostname}" Width="*" />
                                                <DataGridTextColumn Header="RTT" Binding="{Binding RttDisplay}" Width="100" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Border>
                            </TabItem>

                            <!-- Port Prober (Full Width) -->
                            <TabItem>
                                <Border Style="{StaticResource CardStyle}" Margin="0">
                                    <Grid Margin="15">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- Header -->
                                        <TextBlock Grid.Row="0" Text="Outbound Firewall Port Prober" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}" Margin="0,0,0,10"/>

                                        <!-- Controls -->
                                        <Grid Grid.Row="1" Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Select Profile: " VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource TextDarkBrush}" Margin="0,0,10,0"/>
                                            <ComboBox x:Name="CbPortProfile" Grid.Column="1" Height="32" Padding="8,4" SelectionChanged="CbPortProfile_SelectionChanged">
                                                <ComboBoxItem Content="Agilico Connect" IsSelected="True"/>
                                                <ComboBoxItem Content="3CX Phone System"/>
                                                <ComboBoxItem Content="Microsoft Teams"/>
                                                <ComboBoxItem Content="Custom Port Range"/>
                                            </ComboBox>
                                            <Button x:Name="BtnStartPortProbe" Grid.Column="2" Style="{StaticResource ActionButtonStyle}" Content="PROBE PORTS" Click="BtnStartPortProbe_Click" Margin="10,0,0,0" Padding="15,0"/>
                                        </Grid>

                                        <!-- Results Grid -->
                                        <DataGrid Grid.Row="2" x:Name="GridPortProber" AutoGenerateColumns="False" IsReadOnly="True" 
                                                  GridLinesVisibility="Horizontal" HeadersVisibility="Column" Background="Transparent" RowBackground="Transparent" AlternatingRowBackground="#f8fafc" BorderThickness="0" RowHeight="32">
                                            <DataGrid.Resources>
                                                <Style TargetType="DataGridColumnHeader">
                                                    <Setter Property="Background" Value="#f1f5f9"/>
                                                    <Setter Property="Foreground" Value="#64748b"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="Padding" Value="8,6"/>
                                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource BorderLightBrush}"/>
                                                </Style>
                                                <Style TargetType="DataGridCell">
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Padding" Value="8,4"/>
                                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                                </Style>
                                            </DataGrid.Resources>
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Port" Binding="{Binding PortDisplay}" Width="80" />
                                                <DataGridTextColumn Header="Service / Description" Binding="{Binding ServiceName}" Width="*" />
                                                <DataGridTextColumn Header="Target Server" Binding="{Binding Target}" Width="1.2*" />
                                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100">
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="FontWeight" Value="Bold"/>
                                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                                            <Style.Triggers>
                                                                <Trigger Property="Text" Value="Open">
                                                                    <Setter Property="Foreground" Value="#16a34a"/>
                                                                </Trigger>
                                                                <Trigger Property="Text" Value="Blocked">
                                                                    <Setter Property="Foreground" Value="#dc2626"/>
                                                                </Trigger>
                                                                <Trigger Property="Text" Value="Unresponsive">
                                                                    <Setter Property="Foreground" Value="#d97706"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Header="RTT" Binding="{Binding RttDisplay}" Width="60"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Border>
                            </TabItem>

                            <!-- DNS SRV Resolver (Full Width) -->
                            <TabItem>
                                <Border Style="{StaticResource CardStyle}" Margin="0">
                                    <Grid Margin="15">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- Header -->
                                        <TextBlock Grid.Row="0" Text="DNS SRV Service Locator Lookup" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}" Margin="0,0,0,10"/>

                                        <!-- Controls -->
                                        <Grid Grid.Row="1" Margin="0,0,0,15">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="70"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Domain:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource TextDarkBrush}"/>
                                                <TextBox x:Name="TxtSrvDomain" Grid.Column="1" Padding="8,6" Text="sip.agilico.co.uk" BorderBrush="{StaticResource BorderLightBrush}" SelectionBrush="{StaticResource AccentGreenBrush}"/>
                                            </Grid>
                                            <Grid Grid.Row="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="70"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Service:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource TextDarkBrush}"/>
                                                <ComboBox x:Name="CbSrvService" Grid.Column="1" Height="32" Padding="8,4">
                                                    <ComboBoxItem Content="SIP over UDP (_sip._udp)" Tag="_sip._udp" IsSelected="True"/>
                                                    <ComboBoxItem Content="SIP over TCP (_sip._tcp)" Tag="_sip._tcp"/>
                                                    <ComboBoxItem Content="Secure SIP over TCP (_sips._tcp)" Tag="_sips._tcp"/>
                                                    <ComboBoxItem Content="Secure SIP over TLS (_sip._tls)" Tag="_sip._tls"/>
                                                </ComboBox>
                                                <Button x:Name="BtnResolveSrv" Grid.Column="2" Style="{StaticResource ActionButtonStyle}" Content="RESOLVE SRV" Click="BtnResolveSrv_Click" Margin="10,0,0,0" Padding="15,0"/>
                                            </Grid>
                                        </Grid>

                                        <!-- Results Grid -->
                                        <DataGrid Grid.Row="2" x:Name="GridSrvRecords" AutoGenerateColumns="False" IsReadOnly="True" 
                                                  GridLinesVisibility="Horizontal" HeadersVisibility="Column" Background="Transparent" RowBackground="Transparent" AlternatingRowBackground="#f8fafc" BorderThickness="0" RowHeight="32">
                                            <DataGrid.Resources>
                                                <Style TargetType="DataGridColumnHeader">
                                                    <Setter Property="Background" Value="#f1f5f9"/>
                                                    <Setter Property="Foreground" Value="#64748b"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="Padding" Value="8,6"/>
                                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource BorderLightBrush}"/>
                                                </Style>
                                                <Style TargetType="DataGridCell">
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Padding" Value="8,4"/>
                                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                                </Style>
                                            </DataGrid.Resources>
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Priority" Binding="{Binding Priority}" Width="65" />
                                                <DataGridTextColumn Header="Weight" Binding="{Binding Weight}" Width="65" />
                                                <DataGridTextColumn Header="Port" Binding="{Binding Port}" Width="60" />
                                                <DataGridTextColumn Header="Target Host" Binding="{Binding Target}" Width="*" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Border>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </TabItem>

                <!-- TAB 4: PCAP -->
                <TabItem>
                    <Border Style="{StaticResource CardStyle}">
                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Tab Header & Description -->
                            <StackPanel Grid.Row="0" Margin="0,0,0,15">
                                <TextBlock Text="Packet Capture Service (PCAP)" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}"/>
                                <TextBlock Text="The packet capture utility monitors diagnostic network protocols in real-time to analyze compatibility and identify communication bottlenecks." 
                                           TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                            </StackPanel>

                            <!-- Content Area explaining PCAP and showing stats -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Details & Protocols Card -->
                                <Border Grid.Column="0" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,0,1,0" Padding="0,0,20,0" Margin="0,0,20,0">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel>
                                            <TextBlock Text="How Packet Capture Works" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}" Margin="0,0,0,10"/>
                                            <TextBlock Text="When packet capture is started, the utility monitors network traffic. It is capable of capturing raw IP packets on the network interface. You can filter the capture to a specific host IP address, or capture the entire network interface." 
                                                       TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextMutedBrush}" LineHeight="18" Margin="0,0,0,15"/>

                                            <TextBlock Text="Monitored Protocols &amp; Ports:" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextDarkBrush}" Margin="0,0,0,8"/>
                                            <TextBlock Text="• DNS (UDP 53): Domain resolution for service addresses.&#x0a;• HTTP/HTTPS (TCP 80/443): API probes and connectivity tests.&#x0a;• NTP (UDP 123): Time synchronization verification.&#x0a;• STUN (UDP 3478): NAT discovery and firewall binding probes.&#x0a;• SIP ALG (UDP 5060): Session initiation protocol tampering detection.&#x0a;• RTP (UDP Dynamic): Media stream quality simulation (jitter &amp; loss)."
                                                       TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextMutedBrush}" LineHeight="18" Margin="0,0,0,15"/>
                                            
                                            <TextBlock Text="Use the PCAP log file to diagnose packet drop, port rewriting, or deep packet inspection (DPI) interference with your IT department or firewalls administrator." 
                                                       TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextMutedBrush}" FontStyle="Italic" LineHeight="18"/>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>

                                <!-- Real-time Stats & Controls Card -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="10,0,0,0">
                                    <TextBlock Text="Packet Capture Control" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}" Margin="0,0,0,15"/>

                                    <!-- Filter Input -->
                                    <StackPanel Margin="0,0,0,15">
                                        <TextBlock Text="Filter IP Address (Optional):" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,5"/>
                                        <TextBox x:Name="TxtPcapFilterIp" Padding="8,6" BorderBrush="{StaticResource BorderLightBrush}" SelectionBrush="{StaticResource AccentGreenBrush}"/>
                                        <TextBlock Text="Leave blank to capture all network traffic." FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <!-- Start/Stop Capture Button -->
                                    <Button x:Name="BtnTogglePcap" Style="{StaticResource ActionButtonStyle}" Click="BtnTogglePcap_Click" Margin="0,0,0,15">
                                        <TextBlock x:Name="TxtTogglePcap" Text="START CAPTURE"/>
                                    </Button>
                                    
                                    <!-- Download PCAP Button -->
                                    <Button x:Name="BtnDownloadPcapLog" Style="{StaticResource SecondaryButtonStyle}" Click="BtnDownloadPcap_Click" Visibility="Visible" Margin="0,0,0,20">
                                        <TextBlock Text="DOWNLOAD PCAP FILE"/>
                                    </Button>

                                    <Border BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,1,0,0" Padding="0,15,0,0">
                                        <TextBlock Text="Capture Metrics" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextDarkBrush}" Margin="0,0,0,10"/>
                                    </Border>

                                    <!-- Captured Packets -->
                                    <Border Background="#f8fafc" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                                        <Grid>
                                            <TextBlock Text="Captured Packets:" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TxtPcapPackets" Text="0" FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentBlueBrush}" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>

                                    <!-- Data Size -->
                                    <Border Background="#f8fafc" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                                        <Grid>
                                            <TextBlock Text="Data Size:" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TxtPcapSize" Text="0 Bytes" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>

                                    <!-- Recording Duration -->
                                    <Border Background="#f8fafc" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,0">
                                        <Grid>
                                            <TextBlock Text="Duration:" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TxtPcapDuration" Text="0.0s" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </TabItem>

                <!-- TAB 6: RESULTS -->
                <TabItem>
                    <Border Style="{StaticResource CardStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="20">
                                <TextBlock Text="Diagnostic Results" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}" Margin="0,0,0,5"/>
                                <TextBlock Text="Only tests requiring attention are shown below. Passed tests are hidden." FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,20"/>

                                <!-- Default: no results yet -->
                                <StackPanel x:Name="PanelResultsDefault" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,40,0,40">
                                    <Path Data="{StaticResource IconAlert}" Fill="{StaticResource TextMutedBrush}" Width="48" Height="48" Stretch="Uniform" HorizontalAlignment="Center"/>
                                    <TextBlock Text="No Results Available" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextDarkBrush}" HorizontalAlignment="Center" Margin="0,10,0,2"/>
                                    <TextBlock Text="Run diagnostics from the Dashboard to see results here." FontSize="12" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>

                                <!-- All passed -->
                                <StackPanel x:Name="PanelResultsAllPass" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,40,0,40">
                                    <Path Data="{StaticResource IconCheck}" Fill="{StaticResource AccentGreenBrush}" Width="60" Height="60" Stretch="Uniform" HorizontalAlignment="Center"/>
                                    <TextBlock Text="All Tests Passed" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentGreenBrush}" HorizontalAlignment="Center" Margin="0,12,0,4"/>
                                    <TextBlock Text="No issues were detected. Your network is fully compatible with Agilico Connect." 
                                               TextAlignment="Center" TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Width="300" HorizontalAlignment="Center"/>
                                </StackPanel>

                                <!-- Dynamic failed results container -->
                                <StackPanel x:Name="PanelResultsFailed" Visibility="Collapsed">
                                    <Border x:Name="Result1Card" Visibility="Collapsed" Background="#fef2f2" BorderBrush="#fecaca" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="❌ Test 1: DNS Domain &amp; Resolution" FontSize="13" FontWeight="Bold" Foreground="#dc2626"/>
                                            <TextBlock x:Name="Result1Detail" Text="" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,6" TextWrapping="Wrap"/>
                                            <TextBlock Text="→ Check your DNS server settings. Ensure Google DNS (8.8.8.8 / 8.8.4.4) or your corporate DNS can resolve Agilico service domains." 
                                                       FontSize="12" Foreground="#7f1d1d" TextWrapping="Wrap" FontStyle="Italic"/>
                                            <TextBlock Margin="0,6,0,0">
                                                <Hyperlink NavigateUri="https://support.agilico.co.uk/kb/articles/dns-resolution" RequestNavigate="Hyperlink_RequestNavigate">
                                                    Read troubleshooting article
                                                </Hyperlink>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="Result2Card" Visibility="Collapsed" Background="#fef2f2" BorderBrush="#fecaca" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="❌ Test 2: HTTP/HTTPS Outbound" FontSize="13" FontWeight="Bold" Foreground="#dc2626"/>
                                            <TextBlock x:Name="Result2Detail" Text="" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,6" TextWrapping="Wrap"/>
                                            <TextBlock Text="→ Outbound TCP port 80 or 443 is blocked. Ensure web requests to customerportal.hp2k.co.uk are allowed through your firewall or proxy." 
                                                       FontSize="12" Foreground="#7f1d1d" TextWrapping="Wrap" FontStyle="Italic"/>
                                            <TextBlock Margin="0,6,0,0">
                                                <Hyperlink NavigateUri="https://support.agilico.co.uk/kb/articles/outbound-http-probes" RequestNavigate="Hyperlink_RequestNavigate">
                                                    Read troubleshooting article
                                                </Hyperlink>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="Result3Card" Visibility="Collapsed" Background="#fef2f2" BorderBrush="#fecaca" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="❌ Test 3: NTP Time Sync" FontSize="13" FontWeight="Bold" Foreground="#dc2626"/>
                                            <TextBlock x:Name="Result3Detail" Text="" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,6" TextWrapping="Wrap"/>
                                            <TextBlock Text="→ Outbound UDP port 123 (NTP) is blocked. Clients must be able to synchronise time for authentication and call setup." 
                                                       FontSize="12" Foreground="#7f1d1d" TextWrapping="Wrap" FontStyle="Italic"/>
                                            <TextBlock Margin="0,6,0,0">
                                                <Hyperlink NavigateUri="https://support.agilico.co.uk/kb/articles/ntp-time-sync" RequestNavigate="Hyperlink_RequestNavigate">
                                                    Read troubleshooting article
                                                </Hyperlink>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="Result4Card" Visibility="Collapsed" Background="#fef2f2" BorderBrush="#fecaca" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="❌ Test 4: Agilico STUN Servers" FontSize="13" FontWeight="Bold" Foreground="#dc2626"/>
                                            <TextBlock x:Name="Result4Detail" Text="" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,6" TextWrapping="Wrap"/>
                                            <TextBlock Text="→ Agilico STUN servers (UDP port 3478) are unreachable. Check outbound UDP firewall rules." 
                                                       FontSize="12" Foreground="#7f1d1d" TextWrapping="Wrap" FontStyle="Italic"/>
                                            <TextBlock Margin="0,6,0,0">
                                                <Hyperlink NavigateUri="https://support.agilico.co.uk/kb/articles/stun-configuration" RequestNavigate="Hyperlink_RequestNavigate">
                                                    Read troubleshooting article
                                                </Hyperlink>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="Result5Card" Visibility="Collapsed" Background="#fef2f2" BorderBrush="#fecaca" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="❌ Test 5: Google STUN Servers" FontSize="13" FontWeight="Bold" Foreground="#dc2626"/>
                                            <TextBlock x:Name="Result5Detail" Text="" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,6" TextWrapping="Wrap"/>
                                            <TextBlock Text="→ Google backup STUN servers (UDP port 3478) failed to respond. This may indicate broad UDP blocking." 
                                                       FontSize="12" Foreground="#7f1d1d" TextWrapping="Wrap" FontStyle="Italic"/>
                                            <TextBlock Margin="0,6,0,0">
                                                <Hyperlink NavigateUri="https://support.agilico.co.uk/kb/articles/google-stun-backup" RequestNavigate="Hyperlink_RequestNavigate">
                                                    Read troubleshooting article
                                                </Hyperlink>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="Result6Card" Visibility="Collapsed" Background="#fff7ed" BorderBrush="#fed7aa" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="⚠️ Test 6: NAT Routing &amp; Hops" FontSize="13" FontWeight="Bold" Foreground="#c2410c"/>
                                            <TextBlock x:Name="Result6Detail" Text="" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,6" TextWrapping="Wrap"/>
                                            <TextBlock Text="→ Double NAT detected. This can cause intermittent call drops and one-way audio. Simplify your network topology to a single NAT gateway." 
                                                       FontSize="12" Foreground="#7c2d12" TextWrapping="Wrap" FontStyle="Italic"/>
                                            <TextBlock Margin="0,6,0,0">
                                                <Hyperlink NavigateUri="https://support.agilico.co.uk/kb/articles/double-nat-issues" RequestNavigate="Hyperlink_RequestNavigate">
                                                    Read troubleshooting article
                                                </Hyperlink>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="Result7Card" Visibility="Collapsed" Background="#fff7ed" BorderBrush="#fed7aa" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="⚠️ Test 7: NAT Port Randomness" FontSize="13" FontWeight="Bold" Foreground="#c2410c"/>
                                            <TextBlock x:Name="Result7Detail" Text="" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,6" TextWrapping="Wrap"/>
                                            <TextBlock Text="→ NAT port preservation is active. Random/non-preserved NAT ports are recommended for reliable WebRTC ICE negotiation." 
                                                       FontSize="12" Foreground="#7c2d12" TextWrapping="Wrap" FontStyle="Italic"/>
                                            <TextBlock Margin="0,6,0,0">
                                                <Hyperlink NavigateUri="https://support.agilico.co.uk/kb/articles/nat-port-preservation" RequestNavigate="Hyperlink_RequestNavigate">
                                                    Read troubleshooting article
                                                </Hyperlink>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="Result8Card" Visibility="Collapsed" Background="#fef2f2" BorderBrush="#fecaca" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="❌ Test 8: SIP ALG Detection" FontSize="13" FontWeight="Bold" Foreground="#dc2626"/>
                                            <TextBlock x:Name="Result8Detail" Text="" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,6" TextWrapping="Wrap"/>
                                            <TextBlock Text="→ SIP ALG is active or UDP port 5060 is blocked. Disable 'SIP ALG' or 'SIP Helper' in your router/firewall security settings." 
                                                       FontSize="12" Foreground="#7f1d1d" TextWrapping="Wrap" FontStyle="Italic"/>
                                            <TextBlock Margin="0,6,0,0">
                                                <Hyperlink NavigateUri="https://support.agilico.co.uk/kb/articles/disabling-sip-alg" RequestNavigate="Hyperlink_RequestNavigate">
                                                    Read troubleshooting article
                                                </Hyperlink>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="Result9Card" Visibility="Collapsed" Background="#fef2f2" BorderBrush="#fecaca" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="❌ Test 9: RTP Media Quality" FontSize="13" FontWeight="Bold" Foreground="#dc2626"/>
                                            <TextBlock x:Name="Result9Detail" Text="" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,6" TextWrapping="Wrap"/>
                                            <TextBlock Text="→ Severe packet loss or jitter detected on the media path. Check QoS settings, bandwidth utilisation, and ensure UDP traffic is prioritised." 
                                                       FontSize="12" Foreground="#7f1d1d" TextWrapping="Wrap" FontStyle="Italic"/>
                                            <TextBlock Margin="0,6,0,0">
                                                <Hyperlink NavigateUri="https://support.agilico.co.uk/kb/articles/rtp-quality-voip" RequestNavigate="Hyperlink_RequestNavigate">
                                                    Read troubleshooting article
                                                </Hyperlink>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="Result10Card" Visibility="Collapsed" Background="#fef2f2" BorderBrush="#fecaca" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="❌ Test 10: WebSocket Signalling" FontSize="13" FontWeight="Bold" Foreground="#dc2626"/>
                                            <TextBlock x:Name="Result10Detail" Text="" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,6" TextWrapping="Wrap"/>
                                            <TextBlock Text="→ Persistent WebSocket connections to Agilico SignalR hubs are failing. Ensure your proxy/DPI allows WebSocket upgrades on TCP 80/443." 
                                                       FontSize="12" Foreground="#7f1d1d" TextWrapping="Wrap" FontStyle="Italic"/>
                                            <TextBlock Margin="0,6,0,0">
                                                <Hyperlink NavigateUri="https://support.agilico.co.uk/kb/articles/signalr-websockets-connection" RequestNavigate="Hyperlink_RequestNavigate">
                                                    Read troubleshooting article
                                                </Hyperlink>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- Reference: Endpoint Ports -->
                                <Border Background="#eff6ff" BorderBrush="#bfdbfe" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,20,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Agilico Connect V5 Endpoint Reference:" FontSize="13" FontWeight="Bold" Foreground="{StaticResource AccentBlueBrush}" Margin="0,0,0,8"/>
                                        <TextBlock Text="• Signalling Gateway: http://v1.softsignalling.eu-j.hp2k.co.uk/Signals (TCP 80/443)&#x0a;• Media Server IP: 109.73.119.31 (UDP RTP ranges)&#x0a;• Presence Subsystem: http://v3.presence.eu-beta.hp2k.co.uk/Presence (TCP 80/443)&#x0a;• Rooms Subsystem: http://v1.rooms.eu-beta.hp2k.co.uk/Rooms (TCP 80/443)&#x0a;• SIP ALG Check Target: customerportal.hp2k.co.uk (UDP 5060)"
                                                   TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextDarkBrush}" LineHeight="18"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </TabItem>

                <!-- TAB 3: LOGS -->
                <TabItem>
                    <Border Style="{StaticResource CardStyle}">
                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Tab Header -->
                            <StackPanel Grid.Row="0" Margin="0,0,0,15">
                                <TextBlock Text="Activity Logs" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}"/>
                                <TextBlock Text="Detailed diagnostic events for IT administrators and technical support." FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                            </StackPanel>

                            <!-- Log Content TextBox -->
                            <TextBox Grid.Row="1" x:Name="TxtLogs" IsReadOnly="True" 
                                     Background="#0f172a" Foreground="#f8fafc" BorderThickness="0" 
                                     FontFamily="Consolas" FontSize="12" Padding="12" 
                                     AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

                            <!-- Log Actions -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                                <Button x:Name="BtnClearLog" Style="{StaticResource SecondaryButtonStyle}" Content="Clear Log" Click="BtnClearLog_Click" Margin="0,0,10,0"/>
                                <Button x:Name="BtnSaveLog" Style="{StaticResource SecondaryButtonStyle}" Content="Save Log File..." Click="BtnSaveLog_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </TabItem>
                
                <!-- TAB 7: SETTINGS -->
                <TabItem>
                    <Border Style="{StaticResource CardStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid Margin="20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Header -->
                                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                                    <TextBlock Text="Configuration Settings" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}"/>
                                    <TextBlock Text="Adjust parameters used for the environment connectivity testing." FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                                </StackPanel>

                                <!-- Settings Fields -->
                                <StackPanel Grid.Row="1">
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="STUN Server Host/IP:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource TextDarkBrush}"/>
                                        <TextBox x:Name="TxtStunServer" Grid.Column="1" Padding="8,6" Text="stun.sipgate.net" BorderBrush="{StaticResource BorderLightBrush}" SelectionBrush="{StaticResource AccentGreenBrush}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="STUN Server Port:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource TextDarkBrush}"/>
                                        <TextBox x:Name="TxtStunPort" Grid.Column="1" Padding="8,6" Text="3478" BorderBrush="{StaticResource BorderLightBrush}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Local SIP Port to Test:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource TextDarkBrush}"/>
                                        <TextBox x:Name="TxtLocalPort" Grid.Column="1" Padding="8,6" Text="5060" BorderBrush="{StaticResource BorderLightBrush}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="SIP ALG Target Server:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource TextDarkBrush}"/>
                                        <TextBox x:Name="TxtSipAlgServer" Grid.Column="1" Padding="8,6" Text="sip.linphone.org" BorderBrush="{StaticResource BorderLightBrush}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,25">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="SIP ALG Target Port:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource TextDarkBrush}"/>
                                        <TextBox x:Name="TxtSipAlgPort" Grid.Column="1" Padding="8,6" Text="5060" BorderBrush="{StaticResource BorderLightBrush}"/>
                                    </Grid>

                                    <Border BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,1,0,0" Padding="0,15,0,0">
                                        <CheckBox x:Name="ChkSimulation" Content="Enable Offline Simulation Mode (Mock Network Responses)" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextDarkBrush}"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </Border>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
